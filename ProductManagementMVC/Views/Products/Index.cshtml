@model List<BusinessObjects.Models.Product>
@{
    ViewData["Title"] = "Products";
    bool isAdmin = ViewBag.IsAdmin ?? false;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Products</h2>
    @if (isAdmin)
    {
        <a asp-action="Create" class="btn btn-success">+ New Product</a>
    }
</div>

<form method="get" asp-action="Index" class="mb-3">
    <div class="input-group" style="max-width:400px;">
        <input type="text" name="search" value="@ViewBag.Search" class="form-control"
               placeholder="Search by product name..." />
        <button type="submit" class="btn btn-outline-primary">Search</button>
        @if (!string.IsNullOrWhiteSpace(ViewBag.Search as string))
        {
            <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
        }
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">No products found.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Product Name</th>
                    <th>Category</th>
                    <th class="text-center">Units in Stock</th>
                    <th class="text-end">Unit Price</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.ProductID</td>
                        <td>@item.ProductName</td>
                        <td>@item.Category?.CategoryName</td>
                        <td class="text-center">
                            @if (item.UnitsInStock.HasValue)
                            {
                                <span class="badge @(item.UnitsInStock < 10 ? "bg-danger" : "bg-success")">
                                    @item.UnitsInStock
                                </span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="text-end">
                            @(item.UnitPrice.HasValue ? item.UnitPrice.Value.ToString("C") : "—")
                        </td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@item.ProductID"
                               class="btn btn-sm btn-outline-info">Details</a>
                            <a asp-action="Edit" asp-route-id="@item.ProductID"
                               class="btn btn-sm btn-outline-warning">Edit</a>
                            @if (isAdmin)
                            {
                                <a asp-action="Delete" asp-route-id="@item.ProductID"
                                   class="btn btn-sm btn-outline-danger">Delete</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
